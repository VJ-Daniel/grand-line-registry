<link rel="stylesheet" href="/css/main.css" />
<%- include("partials/navbar", { title: "Secret Log Pose" }) %>

<div class="p-8 max-w-4xl mx-auto">
  <div class="alert alert-info mb-6">
    <span><%= log %></span>
  </div>
  <h1 class="text-3xl font-bold mb-2">Destination Reached</h1>

  <p class="mb-8">
    The Log Pose points toward the legendary island of <strong>Wano</strong>.
    Only the strongest pirates of the Straw Hat crew may continue this journey.
  </p>

  <h2 class="text-2xl font-semibold mb-4">
    Active Crew Members
  </h2>

  <table class="table table-zebra w-full">

    <thead>
      <tr>
        <th>Name</th>
        <th>Role</th>
        <th>Status</th>
      </tr>
    </thead>

    <tbody>

      <% for (const member of crew) { %>

        <% if (member.status === "active") { %>

          <tr>
            <td><%= member.name %></td>
            <td><%= member.role %></td>
            <td>
              <span class="badge badge-success">
                Active
              </span>
            </td>
          </tr>

        <% } %>

      <% } %>

    </tbody>

  </table>

</div>